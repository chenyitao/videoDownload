<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:gravity="center_horizontal">
    <ImageView
        android:id="@+id/iv_normal"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="fitCenter"
        android:src="@mipmap/ic_nt_r_sa" />
    <TextView
        android:id="@+id/tv_normal_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/nt_r_title"
        android:textSize="16sp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textFontWeight="500"
        android:lineHeight="20sp"
        android:layout_marginTop="10dp"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ProgressBar
            android:id="@+id/audio"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:indeterminateDrawable="@drawable/anim_nt_bt_large"
            android:layout_marginTop="10dp"/>
        <TextView
            android:id="@+id/tv_normal_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:gravity="center"
            android:text="Get Videos"
            android:textFontWeight="700"
            android:layout_marginTop="10dp"/>
    </RelativeLayout>
</LinearLayout>