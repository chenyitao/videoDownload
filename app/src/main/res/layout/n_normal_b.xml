<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cl_normal_big"
    android:layout_width="match_parent"
    android:layout_height="144dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"
    android:orientation="vertical">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/iv_normal"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_nt_b_vp" />
        <LinearLayout
            android:id="@+id/ll_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="6dp"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_normal_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/nt_title"
                android:textSize="16sp"
                android:textFontWeight="700"
                android:layout_marginBottom="2dp"/>
            <TextView
                android:id="@+id/tv_normal_des"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#666666"
                android:textSize="14sp"
                android:textFontWeight="700"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ProgressBar
            android:id="@+id/audio"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:indeterminateDrawable="@drawable/anim_nt_bt_large" />
        <TextView
            android:id="@+id/tv_normal_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:gravity="center"
            android:text="Get Videos"
            android:textFontWeight="500"/>
    </RelativeLayout>
</LinearLayout>