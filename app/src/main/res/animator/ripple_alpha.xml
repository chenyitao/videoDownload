<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <objectAnimator
        android:propertyName="fillAlpha"
        android:duration="800"
        android:valueFrom="0.2"
        android:valueTo="0"
        android:valueType="floatType"
